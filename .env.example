# ========================================
# RAG 知识库系统 - 环境变量配置模板
# 复制本文件为 .env 并填入真实值
# ========================================

# --- OpenAI 配置（必填）---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- GitHub 配置（爬取私有仓库时必填）---
GITHUB_TOKEN=ghp_your-github-token-here

# --- ChromaDB 配置 ---
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=rag_knowledge_base

# --- RAG 检索配置 ---
RETRIEVAL_TOP_K=5                    # 每次检索返回的文档数
RETRIEVAL_SCORE_THRESHOLD=0.3        # 相似度阈值（0-1，越高越严格）
CHUNK_SIZE=1000                      # 文档分块大小（token数）
CHUNK_OVERLAP=200                    # 分块重叠（保持上下文连续性）

# --- 应用配置 ---
APP_TITLE=RAG 智能知识库
LOG_LEVEL=INFO
MAX_GITHUB_FILES=200                 # 每个仓库最多爬取文件数
